# Runtime DSN — non-superuser role, no BYPASSRLS. The app refuses to boot
# on a privileged connection (RLS would be silently bypassed).
DATABASE_URL=postgresql://thirdpersona_app:localdev_app@localhost:5432/thirdpersona

# Admin DSN — migrations and role provisioning ONLY (scripts/setup_db.py).
# Never give this to the application runtime.
ADMIN_DATABASE_URL=postgresql://thirdpersona:localdev@localhost:5432/thirdpersona

ANTHROPIC_API_KEY=sk-ant-...

# Extraction settings
MIN_EVIDENCE_FLOOR=3
REJECTION_RATE_THRESHOLD=0.4

# Auth: "dev" = X-User-ID header (LOCAL ONLY; refuses to boot in production).
# "jwt" = Bearer tokens verified against your identity provider (Clerk):
#   AUTH_MODE=jwt
#   JWT_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json
#   JWT_ISSUER=https://<your-clerk-domain>
AUTH_MODE=dev
THIRDPERSONA_ENV=development
